{
  "name": "down-detector",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute down-detector-db --file=./schema.sql",
    "db:migrate:remote": "wrangler d1 execute down-detector-db --remote --file=./schema.sql",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241022.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.87.0"
  }
}
